{
  "name": "@sceneworks/ui",
  "version": "0.2.0",
  "description": "Shared SceneWorks design system — OKLCH tokens + theme (dark mode, accents), the app-shell layout, and core React primitives. Consumed by SceneWorks, ChatWorks, and SoundWorks.",
  "license": "Apache-2.0",
  "author": "Michael Trefry and the SceneWorks contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SceneWorks/ui.git"
  },
  "homepage": "https://github.com/SceneWorks/ui#readme",
  "bugs": {
    "url": "https://github.com/SceneWorks/ui/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/sceneworks-ui.js",
  "module": "./dist/sceneworks-ui.js",
  "exports": {
    ".": {
      "import": "./dist/sceneworks-ui.js"
    },
    "./theme.css": "./dist/theme.css",
    "./shell.css": "./dist/shell.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-assets.mjs",
    "prepare": "vite build && node scripts/copy-assets.mjs",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.4.2"
  },
  "keywords": [
    "sceneworks",
    "design-system",
    "ui",
    "react"
  ]
}
